{
  "name": "openterm",
  "version": "1.1.0",
  "description": "AI-Driven SSH Connection Manager",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "node-gyp": "9.4.1",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.openterm.app",
    "productName": "OpenTerm",
    "publish": [
      {
        "provider": "github",
        "owner": "XingZiH",
        "repo": "Openterm"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    }
  }
}
